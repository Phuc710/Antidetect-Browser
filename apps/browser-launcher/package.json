{
  "name": "browser-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Browser Launcher Process",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "playwright": "1.59.1",
    "fingerprint-injector": "workspace:*",
    "fingerprint-generator": "workspace:*",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
