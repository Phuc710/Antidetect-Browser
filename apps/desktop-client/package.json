{
  "name": "desktop-client",
  "version": "0.1.0",
  "private": true,
  "description": "Antidetect Browser Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/main src/preload src/shared --max-warnings=0",
    "test:unit": "node scripts/run-vitest.mjs run --config vitest.config.mts",
    "test:integration": "node scripts/run-vitest.mjs run --config vitest.integration.config.mts",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "migrate": "ts-node migrations/run.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@tanstack/react-query": "^5.56.2",
    "better-sqlite3": "^11.2.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "knex": "^3.1.0",
    "lucide-react": "^0.441.0",
    "playwright": "^1.47.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "shared": "workspace:*",
    "tailwind-merge": "^2.5.2",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "dotenv": "^17.4.2",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.1"
  }
}
